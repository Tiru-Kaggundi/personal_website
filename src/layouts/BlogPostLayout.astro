---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  pubDate: Date;
  description: string;
  tags?: string[];
}

const { title, pubDate, description, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <main class="max-w-2xl mx-auto px-6 pt-12 pb-20">
    <a href="/blog" class="text-sm text-slate-500 hover:text-slate-700">← Back to blog</a>

    <article class="mt-6">
      <header class="mb-10">
        <h1 class="text-4xl font-semibold tracking-tight leading-tight">{title}</h1>
        <div class="mt-3 flex items-center gap-3 text-sm text-slate-500">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {tags && tags.length > 0 && (
            <div class="flex gap-2">
              {tags.map((tag) => (
                <span class="px-2 py-0.5 bg-slate-100 rounded text-xs">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="prose prose-slate max-w-none prose-headings:font-semibold prose-a:text-slate-900">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
