---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog — Tirumala Kaggundi">
  <main class="max-w-2xl mx-auto px-6 pt-12 pb-20">
    <h1 class="text-4xl font-semibold tracking-tight">Blog</h1>
    <p class="mt-2 text-slate-600">Just general thoughts and ramblings...for serious work refer <a href="/projects" class="text-slate-700 hover:underline">projects</a>, <a href="/publications" class="text-slate-700 hover:underline">publications</a> and my <a href="https://indianwesterlies.substack.com" class="text-slate-700 hover:underline">substack</a></p>

    <div class="mt-10 space-y-10">
      {posts.map((post) => (
        <article>
          <a href={`/blog/${post.id}`} class="group block">
            <h2 class="text-2xl font-semibold tracking-tight group-hover:underline">{post.data.title}</h2>
            <time class="text-sm text-slate-500 mt-1 block">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <p class="mt-2 text-slate-600 leading-relaxed">{post.data.description}</p>
          </a>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="mt-2 flex gap-2 text-xs">
              {post.data.tags.map((tag: string) => (
                <span class="px-2 py-0.5 bg-slate-100 rounded text-slate-500">{tag}</span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>

    <div class="mt-16 text-sm text-slate-500">
      Subscribe on <a href="https://indianwesterlies.substack.com" class="text-slate-700 hover:underline">Substack</a> for longer pieces.
    </div>
  </main>
</BaseLayout>
